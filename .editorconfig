# EditorConfig — https://editorconfig.org
# Unreal Engine coding conventions for this plugin.

root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

# C++ / C# / Build files: tabs (Epic UE convention).
[*.{h,hpp,cpp,inl,c,cc,cs,cxx}]
indent_style = tab
indent_size = 4
tab_width = 4

# Unreal build scripts use tabs too.
[*.{Build.cs,Target.cs}]
indent_style = tab
indent_size = 4

# JSON / uplugin / uproject: spaces (tooling-friendly).
[*.{json,uplugin,uproject}]
indent_style = tab
indent_size = 4

# Markdown: spaces; keep trailing whitespace (Markdown hard line breaks).
[*.md]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false

# YAML: spaces.
[*.{yml,yaml}]
indent_style = space
indent_size = 2
